<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Post</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="bg-gradient-to-br from-gray-950 via-gray-900 to-black min-h-screen flex items-center justify-center p-6"
  >
    <!-- CARD -->
    <div
      class="w-full max-w-3xl bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl shadow-2xl p-8 md:p-10"
    >
      <!-- HEADER -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold text-white">✏️ Edit Post</h1>
          <p class="text-gray-400 text-sm mt-1">
            Update your thoughts beautifully
          </p>
        </div>

        <a
          href="/profile"
          class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-white/20 transition"
        >
          ← Back
        </a>
      </div>

      <!-- FORM -->
      <form action="/editpost/<%= post._id %>" method="post" class="space-y-6">
        <!-- TEXTAREA -->
        <div>
          <label class="block text-gray-300 mb-2 font-medium">
            Post Content
          </label>

          <textarea
            name="content"
            rows="8"
            required
            minlength="1"
            placeholder="Write something amazing..."
            class="w-full p-4 rounded-2xl bg-black/30 text-white placeholder-gray-500 border border-white/10 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none text-lg"
          >
<%= post.content %></textarea
          >
        </div>

        <!-- ACTIONS -->
        <div class="flex flex-col sm:flex-row gap-4">
          <button
            type="submit"
            class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition shadow-lg"
          >
            Update Post
          </button>

          <a
            href="/profile"
            class="flex-1 text-center bg-gray-700 hover:bg-gray-600 text-white font-semibold py-3 rounded-xl transition"
          >
            Cancel
          </a>
        </div>
      </form>
    </div>
  </body>
</html>
