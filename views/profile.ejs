<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-gray-900 via-gray-800 to-black min-h-screen p-6">

    <!-- HEADER -->
    <div class="max-w-5xl mx-auto flex items-center justify-between mb-10">
        <h2 class="text-white text-2xl md:text-3xl font-bold">
            Hello, <%= user.username %>
        </h2>

        <a href="/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg shadow-lg transition">
            Logout
        </a>
    </div>

    <!-- MAIN GRID -->
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- CREATE POST -->
        <div class="p-8 rounded-2xl bg-white/10 backdrop-blur-lg border border-white/20 shadow-2xl h-fit">
            <h4 class="text-gray-300 text-lg font-semibold mb-4">
                Create a new post
            </h4>

            <form action="/post" method="post" class="space-y-4">
                <textarea name="content" rows="4" placeholder="Write your post..."
                    class="w-full p-3 rounded-lg bg-white/10 text-white placeholder-gray-400 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>

                <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 transition text-white font-semibold py-2 rounded-lg shadow-lg">
                    Post
                </button>
            </form>
        </div>

        <!-- POSTS -->
        <div class="p-6 rounded-2xl bg-white/10 backdrop-blur-lg border border-white/20 shadow-2xl">

            <h4 class="text-white text-xl font-semibold mb-4">
                Your Posts
            </h4>

            <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2">

                <% if (user.posts && user.posts.length> 0) { %>

                    <% user.posts.slice().reverse().forEach((post)=> { %>

                        <!-- POST CARD -->
                        <div
                            class="p-4 rounded-xl bg-white/10 border border-white/20 text-white shadow-md hover:bg-white/15 transition overflow-hidden">

                            <!-- header -->
                            <div class="flex items-center justify-between mb-3">
                                <h4 class="text-blue-300 font-semibold">
                                    <%= user.username %>
                                </h4>

                                <span class="text-xs text-gray-400">
                                    <%= new Date(post.date).toLocaleDateString() %>
                                </span>
                            </div>

                            <!-- content + likes -->
                            <div class="flex items-start justify-between gap-4">

                                <!-- POST CONTENT -->
                                <p
                                    class="text-gray-200 text-sm leading-relaxed break-words whitespace-pre-wrap flex-1 text-left">
                                    <%= post.content %>
                                </p>

                                <!-- LIKE SECTION -->
                                <div class="flex justify-end shrink-0">
                                    <span class="text-gray-300 text-sm whitespace-nowrap flex items-center gap-1">
                                        👍 <%= post.likes.length %>
                                    </span>
                                </div>

                            </div>

                            <!-- actions -->
                            <div class="flex justify-between text-sm border-t border-white/10 pt-3">

                                <a href="/like/<%= post._id %>"
                                    class="text-green-400 hover:text-green-300 transition font-medium">

                                    <%= post.likes.map(id=> id.toString()).includes(user._id.toString())
                                        ? "👎 Unlike"
                                        : "👍 Like" %>

                                </a>
                                <a href="/editpost/<%= post._id %>"
                                    class="text-yellow-400 hover:text-yellow-300 transition font-medium">
                                    ✏ Edit
                                </a>

                                <a href="/deletepost/<%= post._id %>" class="text-red-400 hover:text-red-300 transition font-medium">
                                    🗑 Delete
                                </a>

                            </div>

                        </div>

                        <% }) %>

                            <% } else { %>

                                <!-- EMPTY STATE -->
                                <div class="text-center py-10">
                                    <p class="text-gray-400 text-sm">
                                        No posts yet 🚀
                                    </p>
                                    <p class="text-gray-500 text-xs mt-1">
                                        Create your first post on the left
                                    </p>
                                </div>

                                <% } %>

            </div>
        </div>

    </div>

</body>

</html>